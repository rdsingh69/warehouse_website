Options -MultiViews -Indexes

# Nuxt 3 SSG: Apache must serve each route's index.html on direct/refresh requests
# Nuxt generates: /about/index.html, /contact/index.html, etc.
# DirectoryIndex tells Apache to serve index.html when a directory is requested
DirectoryIndex index.html

RewriteEngine On
RewriteBase /

# 1. Enforce HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# 2. Serve real files and directories as-is (JS, CSS, images, etc.)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 3. For any path that has a matching /path/index.html, rewrite internally
RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}/index.html -f
RewriteRule ^(.*)$ /$1/index.html [L]

# Security headers
Header always set X-Content-Type-Options "nosniff"
Header always set X-Frame-Options "SAMEORIGIN"
Header always set Referrer-Policy "strict-origin-when-cross-origin"

# Cache static assets
<FilesMatch "\.(js|css|svg|png|jpg|jpeg|gif|ico|woff2?)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# Cache HTML with revalidation
<FilesMatch "\.html$">
  Header set Cache-Control "public, max-age=3600, must-revalidate"
</FilesMatch>
